MEM0_API_URL=http://mem0:8000
MEM0_API_KEY=
MEM0_ADD_PATH=/add
MEM0_SEARCH_PATH=/search
MEM0_DELETE_PATH=/v1/memories/
MEM0_AGENT_ID=github-repo-indexer
MEM0_DIR=/data/mem0

MEM0_LLM_PROVIDER=ollama
MEM0_LLM_MODEL=qwen3.5:4b
MEM0_LLM_TEMPERATURE=0.1
MEM0_EMBEDDER_PROVIDER=ollama
MEM0_EMBEDDER_MODEL=bge-m3
MEM0_EMBEDDING_DIMS=1024
OLLAMA_BASE_URL=http://ollama:11434

# For Ollama Cloud, OpenRouter, or OpenAI-compatible routers, prefer
# MEM0_CONFIG_JSON. See docs/architecture/model-provider-settings.md.

MCP_HOST=0.0.0.0
MCP_PORT=8010
MCP_TRANSPORT=sse

# Copy mem0.policy.example.yml to mem0.policy.yml before compose startup.
MEM0_TENANT_POLICY_FILE=/app/mem0.policy.yml
MEM0_DEFAULT_TENANT=secret-knowledge

CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_ACCESS_CLIENT_ID=
CLOUDFLARE_ACCESS_CLIENT_SECRET=

# Configure these hostnames in Cloudflare Tunnel routing:
# mem0-api.example.com -> http://mem0:8000
# mem0-mcp.example.com -> http://mcp:8010
CLOUDFLARE_MEM0_HOSTNAME=
CLOUDFLARE_MCP_HOSTNAME=

# Optional private access from your own devices through Tailscale.
# See docs/security/tailscale-access.md.
TAILSCALE_MEM0_URL=https://home-server.tailnet-name.ts.net:8443
TAILSCALE_MCP_URL=https://home-server.tailnet-name.ts.net:9443
