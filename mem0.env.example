# Copy this file to mem0.env for local MCP clients and local tools.
# Do not commit mem0.env.

# Use the Cloudflare-protected mem0 API hostname outside Docker Compose.
MEM0_API_URL=https://mem0-api.example.com
# Must match MEM0_API_KEY on the mem0 API runtime when API key enforcement is enabled.
MEM0_API_KEY=

MEM0_ADD_PATH=/add
MEM0_SEARCH_PATH=/search
MEM0_DELETE_PATH=/v1/memories/

# Policy file format: docs/security/policy-format.md
MEM0_TENANT_POLICY_FILE=mem0.policy.yml
# Server-side sanitize-on-add is enforced by the API runtime, not by local MCP clients.
# Sanitizer policy file format: docs/security/policy-format.md
# Set this only when this env file is also used to run the API directly.
# MEM0_SANITIZER_POLICY_FILE=mem0.sanitizer.yml
MEM0_DEFAULT_TENANT=secret-knowledge

# Runtime model defaults used by the compose mem0 API.
MEM0_LLM_PROVIDER=ollama
MEM0_LLM_MODEL=qwen3.5:4b
MEM0_LLM_TEMPERATURE=0.1
MEM0_EMBEDDER_PROVIDER=ollama
MEM0_EMBEDDER_MODEL=bge-m3
MEM0_EMBEDDING_DIMS=1024
OLLAMA_BASE_URL=http://ollama:11434

CLOUDFLARE_ACCESS_CLIENT_ID=
CLOUDFLARE_ACCESS_CLIENT_SECRET=

MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8010
