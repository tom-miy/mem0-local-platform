# Copy this file to mem0.env for local MCP clients and local tools.
# Do not commit mem0.env.

# Use the Cloudflare-protected mem0 API hostname outside Docker Compose.
MEM0_API_URL=https://mem0-api.example.com
MEM0_API_KEY=

MEM0_ADD_PATH=/add
MEM0_SEARCH_PATH=/search
MEM0_DELETE_PATH=/v1/memories/

MEM0_TENANT_POLICY_FILE=mem0.policy.yml
MEM0_DEFAULT_TENANT=secret-knowledge

CLOUDFLARE_ACCESS_CLIENT_ID=
CLOUDFLARE_ACCESS_CLIENT_SECRET=

MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8010
